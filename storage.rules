rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Alumnos / usuarios generales (PDF e imagenes convertidas a PDF)
    match /impresiones/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('image/.*'));
    }

    // Fotos del catalogo
    match /productos/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Expedientes privados (academic tracker)
    match /expedientes/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'mpceciliotopetecruz@gmail.com';
    }

    // Cierre global
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}